# ac-native macOS host Makefile
# Links SDL3 directly (unlike the Linux build which dlopens SDL3 as a fallback).
# Shares QuickJS sources with the Linux build at ../build/quickjs (fetched
# by the Linux Makefile or manually).

CC      ?= clang
BUILD   := build
TARGET  := $(BUILD)/ac-native-macos

# QuickJS sources live alongside the Linux build tree (shared fetch).
QJSDIR  := ../build/quickjs

SDL3_CFLAGS := $(shell pkg-config --cflags sdl3)
SDL3_LIBS   := $(shell pkg-config --libs sdl3)

CFLAGS  := -O2 -Wall -Wextra -std=gnu11 -I. -I../src -I$(QJSDIR) $(SDL3_CFLAGS)
# Carbon is needed for RegisterEventHotKey (global hotkey). ApplicationServices
# + Cocoa come along for free but don't need explicit listing on clang/macOS.
LDFLAGS := $(SDL3_LIBS) -lm -framework Carbon

# Audio backend: AUDIO=core (default) uses a direct CoreAudio AudioUnit;
# AUDIO=sdl uses SDL3's audio stream. Built from separate .c files that
# both implement the macos/audio.h interface. Useful for A/B latency tests.
AUDIO ?= core
ifeq ($(AUDIO),core)
  AUDIO_SRC := audio_coreaudio.c
  AUDIO_FRAMEWORKS := -framework AudioUnit -framework AudioToolbox \
                      -framework CoreAudio -framework CoreFoundation
else ifeq ($(AUDIO),sdl)
  AUDIO_SRC := audio_sdl3.c
  AUDIO_FRAMEWORKS :=
else
  $(error AUDIO must be 'core' or 'sdl')
endif
LDFLAGS += $(AUDIO_FRAMEWORKS)

# Host sources (this directory) + shared synth core from ../src/.
HOST_SRCS := main.c piece.c $(AUDIO_SRC)
HOST_OBJS := $(patsubst %.c,$(BUILD)/%.o,$(HOST_SRCS))

SHARED_SRCS := ../src/synth_core.c
SHARED_OBJS := $(patsubst ../src/%.c,$(BUILD)/shared-%.o,$(SHARED_SRCS))

# QuickJS core object set (must match what the Linux Makefile uses at line 104)
QJS_SRCS  := quickjs.c libunicode.c libregexp.c cutils.c libbf.c
QJS_OBJS  := $(patsubst %.c,$(BUILD)/qjs-%.o,$(QJS_SRCS))

.PHONY: all clean run app app-run compare install uninstall

all: $(TARGET)

# Paths for the .app bundle.
APP_NAME := Notepat
APP_DIR  := $(BUILD)/$(APP_NAME).app
PIECE_SRC := ../pieces/notepat.mjs
LIB_SRC   := ../../../system/public/aesthetic.computer/lib/percussion.mjs

# SDL3 dylib: source path + install-name string the binary links against.
SDL3_LIB_SRC  := /opt/homebrew/lib/libSDL3.0.dylib
SDL3_LIB_NAME := /opt/homebrew/opt/sdl3/lib/libSDL3.0.dylib

# Code-signing identity. Default is ad-hoc (single dash), which is enough
# for local-machine use. Override for distribution:
#   make app SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"
# Use `security find-identity -v -p codesigning` to list available certs.
SIGN_IDENTITY ?= -

# Install path. `make install` drops the signed .app into /Applications
# so it picks up a proper Dock icon and is launchable from Spotlight.
INSTALL_DIR ?= /Applications

# App icon — 1024x1024 PNG generated by scripts/make-icon.py, then packaged
# into AppIcon.icns via iconutil. Target stamps the .iconset dir and emits
# the .icns in $(BUILD).
ICON_SRC     := assets/icon_1024.png
ICON_SET_DIR := $(BUILD)/AppIcon.iconset
ICON_ICNS    := $(BUILD)/AppIcon.icns

$(TARGET): $(HOST_OBJS) $(SHARED_OBJS) $(QJS_OBJS) | $(BUILD)
	$(CC) -o $@ $^ $(LDFLAGS)
	@echo "Built: $@ ($$(wc -c < $@ | tr -d ' ') bytes)"

$(BUILD)/%.o: %.c | $(BUILD)
	$(CC) $(CFLAGS) -c -o $@ $<

$(BUILD)/shared-%.o: ../src/%.c | $(BUILD)
	$(CC) $(CFLAGS) -c -o $@ $<

# QuickJS objects: compiled with the same CONFIG_VERSION the Linux side uses.
# Silence warnings QuickJS itself triggers — we don't own that code.
$(BUILD)/qjs-%.o: $(QJSDIR)/%.c | $(BUILD)
	$(CC) $(CFLAGS) -DCONFIG_VERSION=\"0.8.0\" -Wno-unused-parameter -Wno-sign-compare -Wno-implicit-fallthrough -c -o $@ $<

$(BUILD):
	mkdir -p $(BUILD)

run: $(TARGET)
	$(TARGET)

# Assemble a self-contained .app bundle with notepat + percussion lib +
# libSDL3 embedded. After copying the dylib in, we rewrite install names
# and rpaths so the binary resolves SDL3 through Contents/Frameworks rather
# than brew's /opt/homebrew. Ad-hoc codesign is required on arm64 after any
# install_name_tool modification — otherwise dyld refuses to load the
# tampered Mach-O.
# Build AppIcon.icns from the source PNG. Uses `sips` to downsample into
# every size macOS expects, then `iconutil` to package.
$(ICON_ICNS): $(ICON_SRC) | $(BUILD)
	rm -rf $(ICON_SET_DIR)
	mkdir -p $(ICON_SET_DIR)
	sips -z 16 16     $(ICON_SRC) --out $(ICON_SET_DIR)/icon_16x16.png > /dev/null
	sips -z 32 32     $(ICON_SRC) --out $(ICON_SET_DIR)/icon_16x16@2x.png > /dev/null
	sips -z 32 32     $(ICON_SRC) --out $(ICON_SET_DIR)/icon_32x32.png > /dev/null
	sips -z 64 64     $(ICON_SRC) --out $(ICON_SET_DIR)/icon_32x32@2x.png > /dev/null
	sips -z 128 128   $(ICON_SRC) --out $(ICON_SET_DIR)/icon_128x128.png > /dev/null
	sips -z 256 256   $(ICON_SRC) --out $(ICON_SET_DIR)/icon_128x128@2x.png > /dev/null
	sips -z 256 256   $(ICON_SRC) --out $(ICON_SET_DIR)/icon_256x256.png > /dev/null
	sips -z 512 512   $(ICON_SRC) --out $(ICON_SET_DIR)/icon_256x256@2x.png > /dev/null
	sips -z 512 512   $(ICON_SRC) --out $(ICON_SET_DIR)/icon_512x512.png > /dev/null
	cp $(ICON_SRC)                   $(ICON_SET_DIR)/icon_512x512@2x.png
	iconutil -c icns -o $(ICON_ICNS) $(ICON_SET_DIR)

app: $(TARGET) $(PIECE_SRC) $(LIB_SRC) Info.plist.in $(SDL3_LIB_SRC) $(ICON_ICNS)
	rm -rf $(APP_DIR)
	mkdir -p $(APP_DIR)/Contents/MacOS
	mkdir -p $(APP_DIR)/Contents/Resources/lib
	mkdir -p $(APP_DIR)/Contents/Frameworks
	cp $(TARGET)    $(APP_DIR)/Contents/MacOS/notepat
	cp $(PIECE_SRC) $(APP_DIR)/Contents/Resources/piece.mjs
	cp $(LIB_SRC)   $(APP_DIR)/Contents/Resources/lib/percussion.mjs
	cp $(ICON_ICNS) $(APP_DIR)/Contents/Resources/AppIcon.icns
	cp Info.plist.in $(APP_DIR)/Contents/Info.plist
	cp $(SDL3_LIB_SRC) $(APP_DIR)/Contents/Frameworks/libSDL3.0.dylib
	chmod +w $(APP_DIR)/Contents/Frameworks/libSDL3.0.dylib
	install_name_tool -id @rpath/libSDL3.0.dylib \
	    $(APP_DIR)/Contents/Frameworks/libSDL3.0.dylib
	install_name_tool -change $(SDL3_LIB_NAME) @rpath/libSDL3.0.dylib \
	    $(APP_DIR)/Contents/MacOS/notepat
	-install_name_tool -delete_rpath /opt/homebrew/lib \
	    $(APP_DIR)/Contents/MacOS/notepat 2>/dev/null
	install_name_tool -add_rpath @executable_path/../Frameworks \
	    $(APP_DIR)/Contents/MacOS/notepat
	codesign --force --sign "$(SIGN_IDENTITY)" \
	    $(APP_DIR)/Contents/Frameworks/libSDL3.0.dylib
	codesign --force --options runtime --sign "$(SIGN_IDENTITY)" \
	    --deep $(APP_DIR)
	@echo "Bundle: $(APP_DIR)"
	@echo "--- install names ---"
	@otool -L $(APP_DIR)/Contents/MacOS/notepat | head -5

app-run: app
	open $(APP_DIR)

# Copy the signed .app into /Applications (or $(INSTALL_DIR)). Uses ditto
# instead of cp -R so extended attributes + code signatures survive the
# copy cleanly. Kicks LaunchServices so the new bundle is immediately
# visible to Spotlight / Dock.
install: app
	@if [ ! -w "$(INSTALL_DIR)" ]; then \
		echo "[install] $(INSTALL_DIR) not writable — rerun with sudo or set INSTALL_DIR=..." >&2 ; exit 1 ; fi
	rm -rf "$(INSTALL_DIR)/$(APP_NAME).app"
	ditto "$(APP_DIR)" "$(INSTALL_DIR)/$(APP_NAME).app"
	/System/Library/Frameworks/CoreServices.framework/Versions/A/Frameworks/LaunchServices.framework/Versions/A/Support/lsregister \
	    -f "$(INSTALL_DIR)/$(APP_NAME).app" 2>/dev/null || true
	@echo "[install] $(INSTALL_DIR)/$(APP_NAME).app"
	@codesign --verify --verbose "$(INSTALL_DIR)/$(APP_NAME).app" 2>&1 | head -3 || true

uninstall:
	rm -rf "$(INSTALL_DIR)/$(APP_NAME).app"
	@echo "[uninstall] removed $(INSTALL_DIR)/$(APP_NAME).app"

clean:
	rm -rf $(BUILD)

# A/B the two audio backends: build each, run AC_LATENCY_TEST, print both.
# Lets us quantify whether SDL3's audio stream adds latency vs. a direct
# CoreAudio AudioUnit. RUNS + BUFFER can be overridden on the command line.
RUNS   ?= 40
BUFFER ?= 32
PIECE  ?= ../pieces/notepat.mjs
KEY    ?= c
compare:
	@echo "=== backend: SDL3 ==="
	$(MAKE) -s AUDIO=sdl clean >/dev/null
	$(MAKE) -s AUDIO=sdl >/dev/null
	AC_AUDIO_BUFFER=$(BUFFER) AC_INJECT_KEY=$(KEY) AC_LATENCY_TEST=$(RUNS) $(TARGET) $(PIECE) 2>&1 | grep "^\[\(audio\|latency\)\]"
	@echo
	@echo "=== backend: CoreAudio ==="
	$(MAKE) -s AUDIO=core clean >/dev/null
	$(MAKE) -s AUDIO=core >/dev/null
	AC_AUDIO_BUFFER=$(BUFFER) AC_INJECT_KEY=$(KEY) AC_LATENCY_TEST=$(RUNS) $(TARGET) $(PIECE) 2>&1 | grep "^\[\(audio\|latency\)\]"
