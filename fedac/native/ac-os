#!/bin/bash
# ac-os — Single command for AC Native OS operations
# Usage:
#   ac-os flash        Build everything + flash USB
#   ac-os build        Build everything (no flash)
#   ac-os upload       Upload current build as OTA release
#   ac-os flash+upload Build + flash USB + upload OTA release
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUILD_DIR="${SCRIPT_DIR}/build"
VMLINUZ="${BUILD_DIR}/vmlinuz"
INITRAMFS_ROOT="${BUILD_DIR}/initramfs-root"

CMD="${1:-build}"

log()  { echo -e "\033[0;36m[ac-os]\033[0m $*"; }
err()  { echo -e "\033[0;31m[ac-os]\033[0m $*" >&2; }

# Load env vars (MongoDB, etc.) if not already set
if [ -z "${MONGODB_CONNECTION_STRING:-}" ] && [ -f "/home/me/envs/devcontainer.env" ]; then
    while IFS='=' read -r key value; do
        [[ "$key" =~ ^[[:space:]]*# ]] && continue
        [[ -z "$key" ]] && continue
        key=$(echo "$key" | xargs)
        [ -z "${!key:-}" ] && export "$key=$value" 2>/dev/null || true
    done < /home/me/envs/devcontainer.env
fi

build_binary() {
    log "Building binary..."
    cd "${SCRIPT_DIR}"
    CC_USE="${CC:-}"
    if [ -z "${CC_USE}" ]; then
        if command -v musl-gcc &>/dev/null \
           && echo '#include <linux/input.h>' | musl-gcc -E -x c - &>/dev/null 2>&1; then
            CC_USE=musl-gcc
        else
            CC_USE=gcc
        fi
    fi
    make CC="${CC_USE}" 2>&1 | grep -E "Built:|error:" || true
}

build_initramfs() {
    log "Building initramfs (sudo)..."
    cd "${SCRIPT_DIR}"
    sudo bash scripts/build-and-flash.sh --skip-kernel --skip-binary 2>&1 \
        | grep -E "Baked|KidLisp|Initramfs:|error" || true

    # KidLisp: npx not available under sudo, bundle as user then copy
    local KIDLISP_SRC="${SCRIPT_DIR}/../../system/public/aesthetic.computer/lib/kidlisp.mjs"
    if [ -f "${KIDLISP_SRC}" ] && command -v npx &>/dev/null; then
        log "Bundling KidLisp..."
        npx esbuild "${KIDLISP_SRC}" --bundle --format=iife \
            --global-name=KidLispModule --platform=node \
            --outfile=/tmp/kidlisp-bundle.js 2>&1 | grep -v "^npm warn" || true
        sudo mkdir -p "${INITRAMFS_ROOT}/jslib"
        sudo cp /tmp/kidlisp-bundle.js "${INITRAMFS_ROOT}/jslib/kidlisp-bundle.js"
    fi

    # Copy fresh binary into initramfs
    sudo cp "${BUILD_DIR}/ac-native" "${INITRAMFS_ROOT}/ac-native"

    # Node.js + Claude Code: bundle as user (node installed via fnm, not in sudo PATH)
    local NODE_BIN="$(command -v node 2>/dev/null || true)"
    if [ -n "${NODE_BIN}" ] && [ -f "${NODE_BIN}" ]; then
        log "Bundling Node.js..."
        sudo cp "${NODE_BIN}" "${INITRAMFS_ROOT}/bin/node"
        sudo chmod +x "${INITRAMFS_ROOT}/bin/node"
        for lib in $(ldd "${NODE_BIN}" 2>/dev/null | grep -oP '/\S+'); do
            [ -f "$lib" ] && sudo cp -n "$lib" "${INITRAMFS_ROOT}/lib64/" 2>/dev/null || true
        done
        log "  node: $(du -sh "${INITRAMFS_ROOT}/bin/node" | cut -f1) ($(${NODE_BIN} --version))"

        # Claude Code (x64-linux only, strip other platforms)
        local CLAUDE_PKG="$(npm root -g 2>/dev/null)/@anthropic-ai/claude-code"
        if [ -d "${CLAUDE_PKG}" ]; then
            log "Bundling Claude Code..."
            local CLAUDE_DIR="${INITRAMFS_ROOT}/opt/claude-code"
            sudo mkdir -p "${CLAUDE_DIR}/vendor/ripgrep/x64-linux" \
                         "${CLAUDE_DIR}/vendor/tree-sitter-bash/x64-linux"
            sudo cp "${CLAUDE_PKG}/cli.js" "${CLAUDE_DIR}/"
            sudo cp "${CLAUDE_PKG}/package.json" "${CLAUDE_DIR}/"
            [ -f "${CLAUDE_PKG}/resvg.wasm" ] && sudo cp "${CLAUDE_PKG}/resvg.wasm" "${CLAUDE_DIR}/"
            sudo cp -r "${CLAUDE_PKG}/vendor/ripgrep/x64-linux/"* "${CLAUDE_DIR}/vendor/ripgrep/x64-linux/" 2>/dev/null || true
            sudo cp -r "${CLAUDE_PKG}/vendor/tree-sitter-bash/x64-linux/"* "${CLAUDE_DIR}/vendor/tree-sitter-bash/x64-linux/" 2>/dev/null || true
            # Claude wrapper script
            sudo tee "${INITRAMFS_ROOT}/bin/claude" > /dev/null << 'CLAUDE_WRAPPER'
#!/bin/sh
export HOME="${HOME:-/tmp}"
export TERM="${TERM:-dumb}"
exec /bin/node /opt/claude-code/cli.js "$@"
CLAUDE_WRAPPER
            sudo chmod +x "${INITRAMFS_ROOT}/bin/claude"
            log "  claude-code: $(sudo du -sh "${CLAUDE_DIR}" | cut -f1) (x64-linux only)"
        else
            log "Claude Code not installed globally — skipping"
        fi
    else
        log "Node.js not in PATH — skipping Claude Code bundle"
    fi

    # Repack cpio + lz4
    log "Repacking initramfs..."
    cd "${INITRAMFS_ROOT}"
    sudo find . -print0 | sudo cpio --null -ov --format=newc \
        > "${BUILD_DIR}/initramfs.cpio" 2>/dev/null
    lz4 -l -9 -f "${BUILD_DIR}/initramfs.cpio" "${BUILD_DIR}/initramfs.cpio.lz4"
}

build_kernel() {
    local LINUX_DIR="${BUILD_DIR}/linux-6.14.2"
    if [ ! -d "${LINUX_DIR}" ]; then
        err "Linux source not found at ${LINUX_DIR}"
        exit 1
    fi
    # Sync config-minimal into kernel .config if it's newer
    local CFG_SRC="${SCRIPT_DIR}/kernel/config-minimal"
    if [ -f "${CFG_SRC}" ] && [ "${CFG_SRC}" -nt "${LINUX_DIR}/.config" ]; then
        log "Updating kernel .config from config-minimal..."
        cp "${CFG_SRC}" "${LINUX_DIR}/.config"
        cd "${LINUX_DIR}"
        make olddefconfig 2>&1 | tail -5
    else
        cd "${LINUX_DIR}"
    fi
    # Copy fresh initramfs into kernel tree (kernel embeds it — must be updated!)
    log "Syncing initramfs into kernel tree..."
    sudo cp "${BUILD_DIR}/initramfs.cpio.lz4" "${LINUX_DIR}/initramfs.cpio.lz4"
    # Force kernel to re-embed: remove cached initramfs object (make won't detect content changes)
    sudo rm -f "${LINUX_DIR}/usr/initramfs_data.o" "${LINUX_DIR}/usr/.initramfs_data.o.cmd"
    log "Building kernel..."
    make -j$(nproc) bzImage 2>&1 | tail -1
    sudo cp arch/x86/boot/bzImage "${VMLINUZ}"
    sudo chown $(whoami) "${VMLINUZ}"
    log "Kernel: $(du -sh "${VMLINUZ}" | cut -f1)"
}

record_build() {
    # Record every build in MongoDB (even local/flash-only builds)
    if ! command -v node &>/dev/null; then
        log "Node not available — skipping MongoDB build record"
        return 0
    fi
    local GIT_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    local BUILD_TS=$(date -u '+%Y-%m-%dT%H:%M')
    local SHA=$(sha256sum "${VMLINUZ}" 2>/dev/null | cut -d' ' -f1)
    local SIZE=$(stat -c%s "${VMLINUZ}" 2>/dev/null || echo 0)
    local BUILD_NAME=$(bash scripts/build-name.sh 2>/dev/null || echo "unknown")

    cd "${SCRIPT_DIR}"
    log "Recording build: ${BUILD_NAME} (${GIT_HASH})"
    echo "{
        \"name\": \"${BUILD_NAME}\",
        \"buildNum\": -1,
        \"version\": \"${GIT_HASH}-${BUILD_TS}\",
        \"sha256\": \"${SHA}\",
        \"size\": ${SIZE},
        \"git_hash\": \"${GIT_HASH}\",
        \"build_ts\": \"${BUILD_TS}\",
        \"url\": \"local\",
        \"target\": \"${1:-build}\",
        \"user\": \"${AC_USER_SUB:-${ADMIN_SUB:-unknown}}\"
    }" | node scripts/track-build.mjs record 2>&1 || log "MongoDB record failed (non-fatal)"
}

find_usb_dev() {
    # Find removable USB block device via sysfs
    for dev in sda sdb sdc; do
        if [ -e "/sys/block/${dev}/removable" ]; then
            local rem=$(cat "/sys/block/${dev}/removable" 2>/dev/null)
            if [ "${rem}" = "1" ] && [ -e "/sys/block/${dev}" ]; then
                echo "/dev/${dev}"
                return 0
            fi
        fi
    done
    # Fallback: check sysfs even if not marked removable
    if [ -e "/sys/block/sda" ]; then
        echo "/dev/sda"
        return 0
    fi
    return 1
}

require_login() {
    # Require ac-login before flashing — ensures builds are tied to an authenticated user
    local TOKEN_FILE="${HOME}/.ac-token"
    local LOGIN_SCRIPT="${SCRIPT_DIR}/../../tezos/ac-login.mjs"
    if [ ! -f "${TOKEN_FILE}" ]; then
        if [ -f "${LOGIN_SCRIPT}" ]; then
            log "No token found — starting ac-login..."
            node "${LOGIN_SCRIPT}"
        else
            err "Not logged in and ac-login script not found."
            exit 1
        fi
    fi
    if [ ! -f "${TOKEN_FILE}" ]; then
        err "Login failed or cancelled. Run: ac-login"
        exit 1
    fi
    # Read user sub from token file
    local USER_SUB=$(node -e "const t=JSON.parse(require('fs').readFileSync('${TOKEN_FILE}','utf8')); console.log(t.user?.sub || '')" 2>/dev/null)
    if [ -z "${USER_SUB}" ]; then
        err "Token expired or invalid. Run: ac-login"
        exit 1
    fi
    # Read handle and email too
    local USER_HANDLE=$(node -e "const t=JSON.parse(require('fs').readFileSync('${TOKEN_FILE}','utf8')); console.log(t.user?.handle || t.user?.name || '')" 2>/dev/null)
    local USER_EMAIL=$(node -e "const t=JSON.parse(require('fs').readFileSync('${TOKEN_FILE}','utf8')); console.log(t.user?.email || '')" 2>/dev/null)
    export AC_USER_SUB="${USER_SUB}"
    export AC_USER_HANDLE="${USER_HANDLE}"
    export AC_USER_EMAIL="${USER_EMAIL}"
    log "Authenticated: @${USER_HANDLE} (${USER_SUB})"
}

flash_usb() {
    local USB_DEV
    USB_DEV="$(find_usb_dev)" || { err "No USB device found"; exit 1; }

    log "Flashing to ${USB_DEV}1..."

    # Build config.json from authenticated user (or preserve existing)
    local USB_CONFIG
    if [ -n "${AC_USER_HANDLE:-}" ]; then
        USB_CONFIG=$(node -e "console.log(JSON.stringify({handle:'${AC_USER_HANDLE}',sub:'${AC_USER_SUB}',email:'${AC_USER_EMAIL}'}))" 2>/dev/null)
    else
        USB_CONFIG='{"handle": "unknown"}'
    fi
    log "USB config: ${USB_CONFIG}"

    # Use docker cp + privileged container (bind mounts fail in devcontainers)
    local CONTAINER
    CONTAINER=$(sudo docker create --rm --privileged -v /dev:/dev alpine:latest sh -c "
        set -e
        apk add --quiet dosfstools util-linux mtools

        # Preserve config.json if it exists on the USB
        CONFIG_BAK=''
        mkdir -p /mnt/usb
        if mount ${USB_DEV}1 /mnt/usb 2>/dev/null; then
            if [ -f /mnt/usb/config.json ]; then
                CONFIG_BAK=\$(cat /mnt/usb/config.json)
                echo \"Saved config.json\"
            fi
            umount /mnt/usb
        fi

        # Always clean-slate: wipe partition table, create fresh GPT + EFI partition
        echo 'Wiping and re-partitioning ${USB_DEV}...'
        dd if=/dev/zero of=${USB_DEV} bs=1M count=10 2>/dev/null
        sfdisk --force ${USB_DEV} <<PARTEOF
label: gpt
type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B, size=512M
PARTEOF
        sleep 2
        partprobe ${USB_DEV} 2>/dev/null || true
        sleep 1

        # Format fresh FAT32
        mkfs.vfat -F 32 -n ACBOOT ${USB_DEV}1

        # Mount and copy kernel
        mount ${USB_DEV}1 /mnt/usb
        mkdir -p /mnt/usb/EFI/BOOT
        cp /tmp/vmlinuz /mnt/usb/EFI/BOOT/BOOTX64.EFI

        # Write config.json with authenticated user data
        printf '%s' '${USB_CONFIG}' > /mnt/usb/config.json
        echo \"Wrote config.json\"

        sync && sleep 2 && sync
        echo '=== Verify ==='
        sha256sum /mnt/usb/EFI/BOOT/BOOTX64.EFI /tmp/vmlinuz
        cat /mnt/usb/config.json
        umount /mnt/usb
        echo 'Flashed!'
    ")
    sudo docker cp "${VMLINUZ}" "${CONTAINER}:/tmp/vmlinuz"
    sudo docker start -a "${CONTAINER}" 2>&1
}

load_vault_creds() {
    # Decrypt DO Spaces credentials from vault GPG file
    # Tries: 1) already in env, 2) plaintext cache, 3) GPG decrypt (agent or prompt)
    if [ -n "${DO_SPACES_KEY:-}" ] && [ -n "${DO_SPACES_SECRET:-}" ]; then
        return 0
    fi

    local CACHE="/tmp/.ac-upload-env"
    if [ -f "${CACHE}" ]; then
        set -a; source "${CACHE}"; set +a
        if [ -n "${DO_SPACES_KEY:-}" ] && [ -n "${DO_SPACES_SECRET:-}" ]; then
            log "Credentials loaded from session cache"
            return 0
        fi
    fi

    # Find the encrypted file
    local GPG_FILE=""
    for candidate in \
        "${SCRIPT_DIR}/upload.env.gpg" \
        "${SCRIPT_DIR}/../../aesthetic-computer-vault/fedac/native/upload.env.gpg" \
        "/home/me/aesthetic-computer-vault/fedac/native/upload.env.gpg"; do
        if [ -f "${candidate}" ]; then
            GPG_FILE="${candidate}"
            break
        fi
    done

    if [ -z "${GPG_FILE}" ]; then
        err "No upload.env.gpg found in vault or local paths"
        err "Expected locations:"
        err "  ${SCRIPT_DIR}/upload.env.gpg"
        err "  aesthetic-computer-vault/fedac/native/upload.env.gpg"
        return 1
    fi

    log "Decrypting credentials from $(basename "${GPG_FILE}")..."

    # Try GPG agent first (no tty needed if key is cached)
    local DECRYPTED
    DECRYPTED=$(gpg --batch --pinentry-mode loopback -d "${GPG_FILE}" 2>/dev/null | grep "=") || true

    # If agent didn't have it cached, prompt for passphrase
    if [ -z "${DECRYPTED}" ]; then
        if [ -t 0 ]; then
            # Interactive terminal — let GPG prompt naturally
            log "GPG agent needs passphrase..."
            DECRYPTED=$(gpg --pinentry-mode loopback -d "${GPG_FILE}" 2>/dev/null | grep "=") || true
        fi
    fi

    if [ -z "${DECRYPTED}" ]; then
        err "Failed to decrypt ${GPG_FILE}"
        err "Import your key: gpg --import <key.asc>"
        err "Then retry — GPG will prompt for your passphrase"
        return 1
    fi

    # Cache decrypted creds for this session (readable only by us)
    echo "${DECRYPTED}" > "${CACHE}"
    chmod 600 "${CACHE}"

    set -a; eval "${DECRYPTED}"; set +a
    log "Credentials decrypted and cached for session"
}

generate_template_img() {
    # Create a bootable FAT32 disk image with the kernel + default config.
    # Uses mtools (mcopy/mmd) to avoid needing loop devices or mount.
    # The config.json is padded to 4096 bytes for easy byte-patching.
    local IMG="/tmp/ac-native.img"
    local KERNEL_SIZE=$(stat -c%s "${VMLINUZ}")
    # Minimum 128MB for UEFI compat (kernel now includes Node.js + Claude Code).
    # Some firmware ignores tiny GPT disks or fails backup-GPT validation
    # when the image is dd'd / Balena-flashed onto a larger drive.
    local MIN_MB=128
    local NEED_MB=$(( (KERNEL_SIZE / 1048576) + 4 ))
    local IMG_SIZE_MB=$(( NEED_MB > MIN_MB ? NEED_MB : MIN_MB ))

    log "Generating template .img (${IMG_SIZE_MB}MB)..." >&2

    # Create empty image
    dd if=/dev/zero of="${IMG}" bs=1M count=${IMG_SIZE_MB} status=none

    # Create GPT partition table with EFI System Partition (fills image)
    sfdisk "${IMG}" --quiet <<EOF
label: gpt
type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B
EOF

    # Find the partition offset (skip GPT header, typically 1MB = 2048 sectors)
    local PART_START=$(sfdisk -d "${IMG}" 2>/dev/null | grep "start=" | head -1 | sed 's/.*start= *\([0-9]*\).*/\1/')
    PART_START=${PART_START:-2048}
    local PART_OFFSET=$(( PART_START * 512 ))

    # Extract just the partition into a separate file for mtools
    local PART_IMG="/tmp/ac-native-part.img"
    local PART_SIZE=$(( IMG_SIZE_MB * 1048576 - PART_OFFSET ))
    dd if="${IMG}" of="${PART_IMG}" bs=512 skip=${PART_START} status=none

    # Format as FAT32
    mkfs.vfat -F 32 -n AC-NATIVE "${PART_IMG}" >/dev/null 2>&1

    # Create EFI directory structure using mtools
    export MTOOLS_SKIP_CHECK=1
    mmd -i "${PART_IMG}" ::EFI ::EFI/BOOT 2>/dev/null

    # Copy kernel
    mcopy -o -i "${PART_IMG}" "${VMLINUZ}" ::EFI/BOOT/BOOTX64.EFI

    # Create padded config.json (4096 bytes, space-padded)
    local CONFIG_TMP="/tmp/ac-config-template.json"
    printf '{"handle":"","piece":"notepat","sub":"","email":""}' > "${CONFIG_TMP}"
    local CURRENT_SIZE=$(stat -c%s "${CONFIG_TMP}")
    local PAD_SIZE=$((4096 - CURRENT_SIZE))
    dd if=/dev/zero bs=1 count=${PAD_SIZE} 2>/dev/null | tr '\0' ' ' >> "${CONFIG_TMP}"
    mcopy -o -i "${PART_IMG}" "${CONFIG_TMP}" ::config.json

    # Write the partition back into the disk image
    dd if="${PART_IMG}" of="${IMG}" bs=512 seek=${PART_START} conv=notrunc status=none

    rm -f "${PART_IMG}" "${CONFIG_TMP}"

    # Gzip compress — Balena Etcher handles .img.gz natively
    log "Compressing template .img..." >&2
    gzip -f "${IMG}"
    local GZ="${IMG}.gz"

    local GZ_BYTES=$(stat -c%s "${GZ}")
    local RAW_MB=$(( IMG_SIZE_MB ))
    local GZ_MB=$(( GZ_BYTES / 1048576 ))
    log "Template image: ${GZ} (${GZ_MB}MB compressed from ${RAW_MB}MB)" >&2
    echo "${GZ}"
}

upload_ota() {
    log "Uploading OTA release..."
    cd "${SCRIPT_DIR}"

    # Get AC token from ac-login
    local TOKEN_FILE="${HOME}/.ac-token"
    if [ ! -f "${TOKEN_FILE}" ]; then
        err "Not logged in. Run: ac-login"
        exit 1
    fi
    local AC_TOKEN=$(node -e "const t=JSON.parse(require('fs').readFileSync('${TOKEN_FILE}','utf8')); console.log(t.access_token || '')" 2>/dev/null)
    if [ -z "${AC_TOKEN}" ]; then
        err "Token missing or expired. Run: ac-login"
        exit 1
    fi

    # Build metadata
    local GIT_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    if ! git diff --quiet HEAD 2>/dev/null; then
        GIT_HASH="${GIT_HASH}-dirty"
    fi
    local BUILD_TS=$(date -u '+%Y-%m-%dT%H:%M')
    local BUILD_NAME=$(bash scripts/build-name.sh 2>/dev/null || echo "upload-$(date +%s)")
    local COMMIT_MSG=$(git log -1 --format=%s HEAD 2>/dev/null | head -c 200)
    local SIZE=$(stat -c%s "${VMLINUZ}")
    local SIZE_MB=$(( SIZE / 1048576 ))
    local SHA=$(sha256sum "${VMLINUZ}" | cut -d' ' -f1)

    log "Uploading ${BUILD_NAME} (${GIT_HASH}, ${SIZE_MB}MB)..."

    local UPLOAD_URL="${AC_UPLOAD_URL:-https://aesthetic.computer/api/os-release-upload}"

    # Step 1: Get presigned S3 URL from edge function
    local STEP1
    STEP1=$(curl -sf -X POST "${UPLOAD_URL}" \
        -H "Authorization: Bearer ${AC_TOKEN}" \
        -H "X-Build-Name: ${BUILD_NAME}" \
        -H "X-Git-Hash: ${GIT_HASH}" \
        -H "X-Build-Ts: ${BUILD_TS}" \
        -H "X-Commit-Msg: ${COMMIT_MSG}" \
        -H "X-Handle: ${AC_USER_HANDLE}" \
        --max-time 30) || {
        err "Failed to get upload URL. Check connection or run: ac-login"
        exit 1
    }

    local PUT_URL=$(echo "$STEP1" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.parse(d).vmlinuz_put_url||''))" 2>/dev/null)
    if [ -z "${PUT_URL}" ]; then
        err "No presigned URL returned: ${STEP1}"
        exit 1
    fi

    log "Uploading vmlinuz directly to S3..."

    # Step 2: Upload vmlinuz directly to DO Spaces via presigned URL
    curl -sf -X PUT "${PUT_URL}" \
        -H "Content-Type: application/octet-stream" \
        -H "x-amz-acl: public-read" \
        --data-binary "@${VMLINUZ}" \
        --max-time 300 || {
        err "S3 upload failed"
        exit 1
    }

    log "Finalizing release..."

    # Step 3: Tell edge function to update metadata + releases.json
    local RESPONSE
    RESPONSE=$(curl -sf -X POST "${UPLOAD_URL}" \
        -H "Authorization: Bearer ${AC_TOKEN}" \
        -H "X-Build-Name: ${BUILD_NAME}" \
        -H "X-Git-Hash: ${GIT_HASH}" \
        -H "X-Build-Ts: ${BUILD_TS}" \
        -H "X-Commit-Msg: ${COMMIT_MSG}" \
        -H "X-Finalize: true" \
        -H "X-Sha256: ${SHA}" \
        -H "X-Size: ${SIZE}" \
        -H "X-Handle: ${AC_USER_HANDLE}" \
        --max-time 30) || {
        err "Finalize failed"
        exit 1
    }

    # Parse response
    local NAME=$(echo "$RESPONSE" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.parse(d).name||''))" 2>/dev/null)
    local URL=$(echo "$RESPONSE" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.parse(d).url||''))" 2>/dev/null)

    log "Published: ${NAME}"
    log "  SHA: ${SHA}"
    log "  URL: ${URL}"

    # Step 4: Generate and upload template .img for personalized downloads
    local TEMPLATE_IMG
    TEMPLATE_IMG=$(generate_template_img) && {
        log "Uploading template .img..."
        # Get presigned URL for the .img
        local IMG_STEP
        IMG_STEP=$(curl -sf -X POST "${UPLOAD_URL}" \
            -H "Authorization: Bearer ${AC_TOKEN}" \
            -H "X-Build-Name: ${BUILD_NAME}" \
            -H "X-Template-Upload: true" \
            --max-time 30) || { log "Template presign failed (non-fatal)"; }

        if [ -n "${IMG_STEP}" ]; then
            local IMG_PUT_URL=$(echo "$IMG_STEP" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.parse(d).img_put_url||''))" 2>/dev/null)
            if [ -n "${IMG_PUT_URL}" ] && [ -f "${TEMPLATE_IMG}" ]; then
                log "Uploading template $(stat -c%s "${TEMPLATE_IMG}" | numfmt --to=iec) to S3..."
                curl -sf -X PUT "${IMG_PUT_URL}" \
                    -H "Content-Type: application/gzip" \
                    -H "x-amz-acl: public-read" \
                    -T "${TEMPLATE_IMG}" \
                    --max-time 300 && {
                    log "Template .img uploaded"
                    # Flush oven's in-memory cache so downloads get the new template immediately
                    curl -sf -X POST "https://oven.aesthetic.computer/os-cache-flush" \
                        --max-time 10 && log "Oven template cache flushed" \
                        || log "Cache flush failed (non-fatal)"
                } || log "Template upload failed (non-fatal)"
            fi
        fi
        rm -f "${TEMPLATE_IMG}"
    } || log "Template generation failed (non-fatal)"

    # Record in MongoDB
    if command -v node &>/dev/null; then
        echo "{
            \"name\": \"${BUILD_NAME}\",
            \"buildNum\": -1,
            \"version\": \"${GIT_HASH}-${BUILD_TS}\",
            \"sha256\": \"${SHA}\",
            \"size\": ${SIZE},
            \"git_hash\": \"${GIT_HASH}\",
            \"build_ts\": \"${BUILD_TS}\",
            \"url\": \"${URL}\",
            \"target\": \"upload\",
            \"user\": \"${AC_USER_SUB:-${ADMIN_SUB:-unknown}}\"
        }" | node scripts/track-build.mjs record 2>&1 || log "MongoDB record failed (non-fatal)"
    fi
}

case "${CMD}" in
    build)
        build_binary
        build_initramfs
        build_kernel
        record_build "build"
        log "Build complete: ${VMLINUZ}"
        ;;
    flash)
        build_binary
        build_initramfs
        build_kernel
        record_build "flash"
        flash_usb
        ;;
    upload)
        require_login
        # OTA releases must come from a clean, committed state
        if ! git diff --quiet HEAD 2>/dev/null || ! git diff --cached --quiet HEAD 2>/dev/null; then
            err "Uncommitted changes detected. Commit first — OTA builds must be clean."
            exit 1
        fi
        build_binary
        build_initramfs
        build_kernel
        record_build "upload"
        upload_ota
        ;;
    flash+upload|upload+flash|bfu)
        require_login
        if ! git diff --quiet HEAD 2>/dev/null || ! git diff --cached --quiet HEAD 2>/dev/null; then
            err "Uncommitted changes detected. Commit first — OTA builds must be clean."
            exit 1
        fi
        build_binary
        build_initramfs
        build_kernel
        record_build "flash+upload"
        flash_usb
        upload_ota
        ;;
    *)
        echo "Usage: ac-os {build|flash|upload|flash+upload|bfu}"
        exit 1
        ;;
esac
