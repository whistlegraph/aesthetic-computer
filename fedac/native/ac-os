#!/bin/bash
# ac-os — Single command for AC Native OS operations
# Usage:
#   ac-os flash        Build everything + flash USB
#   ac-os build        Build everything (no flash)
#   ac-os upload       Upload current build as OTA release
#   ac-os flash+upload Build + flash USB + upload OTA release
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUILD_DIR="${SCRIPT_DIR}/build"
VMLINUZ="${BUILD_DIR}/vmlinuz"
INITRAMFS_ROOT="${BUILD_DIR}/initramfs-root"

CMD="${1:-build}"

log()  { echo -e "\033[0;36m[ac-os]\033[0m $*"; }
err()  { echo -e "\033[0;31m[ac-os]\033[0m $*" >&2; }

# Load env vars (MongoDB, etc.) if not already set
if [ -z "${MONGODB_CONNECTION_STRING:-}" ] && [ -f "/home/me/envs/devcontainer.env" ]; then
    while IFS='=' read -r key value; do
        [[ "$key" =~ ^[[:space:]]*# ]] && continue
        [[ -z "$key" ]] && continue
        key=$(echo "$key" | xargs)
        [ -z "${!key:-}" ] && export "$key=$value" 2>/dev/null || true
    done < /home/me/envs/devcontainer.env
fi

build_binary() {
    log "Building binary..."
    cd "${SCRIPT_DIR}"
    CC_USE="${CC:-}"
    if [ -z "${CC_USE}" ]; then
        if command -v musl-gcc &>/dev/null \
           && echo '#include <linux/input.h>' | musl-gcc -E -x c - &>/dev/null 2>&1; then
            CC_USE=musl-gcc
        else
            CC_USE=gcc
        fi
    fi
    make CC="${CC_USE}" 2>&1 | grep -E "Built:|error:" || true
}

build_initramfs() {
    log "Building initramfs (sudo)..."
    cd "${SCRIPT_DIR}"
    sudo bash scripts/build-and-flash.sh --skip-kernel --skip-binary 2>&1 \
        | grep -E "Baked|KidLisp|Initramfs:|error" || true

    # KidLisp: npx not available under sudo, bundle as user then copy
    local KIDLISP_SRC="${SCRIPT_DIR}/../../system/public/aesthetic.computer/lib/kidlisp.mjs"
    if [ -f "${KIDLISP_SRC}" ] && command -v npx &>/dev/null; then
        log "Bundling KidLisp..."
        npx esbuild "${KIDLISP_SRC}" --bundle --format=iife \
            --global-name=KidLispModule --platform=node \
            --outfile=/tmp/kidlisp-bundle.js 2>&1 | grep -v "^npm warn" || true
        sudo mkdir -p "${INITRAMFS_ROOT}/jslib"
        sudo cp /tmp/kidlisp-bundle.js "${INITRAMFS_ROOT}/jslib/kidlisp-bundle.js"
    fi

    # Copy fresh binary into initramfs
    sudo cp "${BUILD_DIR}/ac-native" "${INITRAMFS_ROOT}/ac-native"

    # Repack cpio + lz4
    log "Repacking initramfs..."
    cd "${INITRAMFS_ROOT}"
    sudo find . -print0 | sudo cpio --null -ov --format=newc \
        > "${BUILD_DIR}/initramfs.cpio" 2>/dev/null
    lz4 -l -9 -f "${BUILD_DIR}/initramfs.cpio" "${BUILD_DIR}/initramfs.cpio.lz4"
}

build_kernel() {
    local LINUX_DIR="${BUILD_DIR}/linux-6.14.2"
    if [ ! -d "${LINUX_DIR}" ]; then
        err "Linux source not found at ${LINUX_DIR}"
        exit 1
    fi
    # Sync config-minimal into kernel .config if it's newer
    local CFG_SRC="${SCRIPT_DIR}/kernel/config-minimal"
    if [ -f "${CFG_SRC}" ] && [ "${CFG_SRC}" -nt "${LINUX_DIR}/.config" ]; then
        log "Updating kernel .config from config-minimal..."
        cp "${CFG_SRC}" "${LINUX_DIR}/.config"
        cd "${LINUX_DIR}"
        make olddefconfig 2>&1 | tail -5
    else
        cd "${LINUX_DIR}"
    fi
    # Copy fresh initramfs into kernel tree (kernel embeds it — must be updated!)
    log "Syncing initramfs into kernel tree..."
    sudo cp "${BUILD_DIR}/initramfs.cpio.lz4" "${LINUX_DIR}/initramfs.cpio.lz4"
    # Force kernel to re-embed: remove cached initramfs object (make won't detect content changes)
    sudo rm -f "${LINUX_DIR}/usr/initramfs_data.o" "${LINUX_DIR}/usr/.initramfs_data.o.cmd"
    log "Building kernel..."
    make -j$(nproc) bzImage 2>&1 | tail -1
    cp arch/x86/boot/bzImage "${VMLINUZ}"
    log "Kernel: $(du -sh "${VMLINUZ}" | cut -f1)"
}

find_usb_dev() {
    # Find removable USB block device via sysfs
    for dev in sda sdb sdc; do
        if [ -e "/sys/block/${dev}/removable" ]; then
            local rem=$(cat "/sys/block/${dev}/removable" 2>/dev/null)
            if [ "${rem}" = "1" ] && [ -e "/sys/block/${dev}" ]; then
                echo "/dev/${dev}"
                return 0
            fi
        fi
    done
    # Fallback: check sysfs even if not marked removable
    if [ -e "/sys/block/sda" ]; then
        echo "/dev/sda"
        return 0
    fi
    return 1
}

flash_usb() {
    local USB_DEV
    USB_DEV="$(find_usb_dev)" || { err "No USB device found"; exit 1; }

    log "Flashing to ${USB_DEV}1..."

    # Use docker cp + privileged container (bind mounts fail in devcontainers)
    local CONTAINER
    CONTAINER=$(sudo docker create --rm --privileged -v /dev:/dev alpine:latest sh -c "
        set -e
        apk add --quiet dosfstools util-linux mtools

        # Preserve config.json if it exists on the USB
        CONFIG_BAK=''
        mkdir -p /mnt/usb
        if mount ${USB_DEV}1 /mnt/usb 2>/dev/null; then
            if [ -f /mnt/usb/config.json ]; then
                CONFIG_BAK=\$(cat /mnt/usb/config.json)
                echo \"Saved config.json\"
            fi
            umount /mnt/usb
        fi

        # Always clean-slate: wipe partition table, create fresh GPT + EFI partition
        echo 'Wiping and re-partitioning ${USB_DEV}...'
        dd if=/dev/zero of=${USB_DEV} bs=1M count=10 2>/dev/null
        sfdisk --force ${USB_DEV} <<PARTEOF
label: gpt
type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B, size=512M
PARTEOF
        sleep 2
        partprobe ${USB_DEV} 2>/dev/null || true
        sleep 1

        # Format fresh FAT32
        mkfs.vfat -F 32 -n ACBOOT ${USB_DEV}1

        # Mount and copy kernel
        mount ${USB_DEV}1 /mnt/usb
        mkdir -p /mnt/usb/EFI/BOOT
        cp /tmp/vmlinuz /mnt/usb/EFI/BOOT/BOOTX64.EFI

        # Restore config.json (or create default)
        if [ -n \"\${CONFIG_BAK}\" ]; then
            printf '%s' \"\${CONFIG_BAK}\" > /mnt/usb/config.json
            echo \"Restored config.json\"
        else
            printf '{\"handle\": \"jeffrey\"}' > /mnt/usb/config.json
            echo \"Created default config.json\"
        fi

        sync && sleep 2 && sync
        echo '=== Verify ==='
        sha256sum /mnt/usb/EFI/BOOT/BOOTX64.EFI /tmp/vmlinuz
        cat /mnt/usb/config.json
        umount /mnt/usb
        echo 'Flashed!'
    ")
    sudo docker cp "${VMLINUZ}" "${CONTAINER}:/tmp/vmlinuz"
    sudo docker start -a "${CONTAINER}" 2>&1
}

load_vault_creds() {
    # Decrypt DO Spaces credentials from vault GPG file
    # Tries: 1) already in env, 2) plaintext cache, 3) GPG decrypt (agent or prompt)
    if [ -n "${DO_SPACES_KEY:-}" ] && [ -n "${DO_SPACES_SECRET:-}" ]; then
        return 0
    fi

    local CACHE="/tmp/.ac-upload-env"
    if [ -f "${CACHE}" ]; then
        set -a; source "${CACHE}"; set +a
        if [ -n "${DO_SPACES_KEY:-}" ] && [ -n "${DO_SPACES_SECRET:-}" ]; then
            log "Credentials loaded from session cache"
            return 0
        fi
    fi

    # Find the encrypted file
    local GPG_FILE=""
    for candidate in \
        "${SCRIPT_DIR}/upload.env.gpg" \
        "${SCRIPT_DIR}/../../aesthetic-computer-vault/fedac/native/upload.env.gpg" \
        "/home/me/aesthetic-computer-vault/fedac/native/upload.env.gpg"; do
        if [ -f "${candidate}" ]; then
            GPG_FILE="${candidate}"
            break
        fi
    done

    if [ -z "${GPG_FILE}" ]; then
        err "No upload.env.gpg found in vault or local paths"
        err "Expected locations:"
        err "  ${SCRIPT_DIR}/upload.env.gpg"
        err "  aesthetic-computer-vault/fedac/native/upload.env.gpg"
        return 1
    fi

    log "Decrypting credentials from $(basename "${GPG_FILE}")..."

    # Try GPG agent first (no tty needed if key is cached)
    local DECRYPTED
    DECRYPTED=$(gpg --batch --pinentry-mode loopback -d "${GPG_FILE}" 2>/dev/null | grep "=") || true

    # If agent didn't have it cached, prompt for passphrase
    if [ -z "${DECRYPTED}" ]; then
        if [ -t 0 ]; then
            # Interactive terminal — let GPG prompt naturally
            log "GPG agent needs passphrase..."
            DECRYPTED=$(gpg --pinentry-mode loopback -d "${GPG_FILE}" 2>/dev/null | grep "=") || true
        fi
    fi

    if [ -z "${DECRYPTED}" ]; then
        err "Failed to decrypt ${GPG_FILE}"
        err "Import your key: gpg --import <key.asc>"
        err "Then retry — GPG will prompt for your passphrase"
        return 1
    fi

    # Cache decrypted creds for this session (readable only by us)
    echo "${DECRYPTED}" > "${CACHE}"
    chmod 600 "${CACHE}"

    set -a; eval "${DECRYPTED}"; set +a
    log "Credentials decrypted and cached for session"
}

upload_ota() {
    log "Uploading OTA release..."
    load_vault_creds || exit 1
    export DO_SPACES_KEY DO_SPACES_SECRET DO_SPACES_BUCKET DO_SPACES_REGION
    cd "${SCRIPT_DIR}"
    bash scripts/upload-release.sh "${VMLINUZ}"
}

case "${CMD}" in
    build)
        build_binary
        build_initramfs
        build_kernel
        log "Build complete: ${VMLINUZ}"
        ;;
    flash)
        build_binary
        build_initramfs
        build_kernel
        flash_usb
        ;;
    upload)
        upload_ota
        ;;
    flash+upload|upload+flash|bfu)
        build_binary
        build_initramfs
        build_kernel
        flash_usb
        upload_ota
        ;;
    *)
        echo "Usage: ac-os {build|flash|upload|flash+upload|bfu}"
        exit 1
        ;;
esac
