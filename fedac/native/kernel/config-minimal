# Minimal kernel config for ac-native sub-second boot
# Target: EFI stub boot, DRM/KMS, evdev, HDA audio, USB
# No modules — everything built-in
# No network (Phase 1-3)

# === General ===
CONFIG_LOCALVERSION="-ac-native"
# CONFIG_MODULES is not set
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_EMBEDDED=y
CONFIG_EXPERT=y
CONFIG_PROFILING=n

# === Boot / EFI ===
CONFIG_EFI_STUB=y
CONFIG_EFI=y
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE="console=tty0 quiet loglevel=0 init=/init mitigations=off"

# === Initramfs ===
# For built-in: CONFIG_INITRAMFS_SOURCE="/path/to/initramfs.cpio"
# For external initrd (-initrd flag in QEMU):
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_LZ4=y
CONFIG_INITRAMFS_COMPRESSION_LZ4=y

# === Filesystems (minimal) ===
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
# CONFIG_EXT4_FS is not set
# CONFIG_FUSE_FS is not set
# CONFIG_NFS_FS is not set
# CONFIG_CIFS is not set
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y

# === Display / DRM ===
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y

# Intel GPU (ThinkPad, most laptops)
CONFIG_DRM_I915=y

# AMD GPU (broader hardware)
CONFIG_DRM_AMDGPU=y
# CONFIG_DRM_AMDGPU_CIK is not set
# CONFIG_DRM_AMDGPU_SI is not set

# QEMU display support
CONFIG_DRM_BOCHS=y
CONFIG_DRM_QXL=y
CONFIG_DRM_CIRRUS_QEMU=y

# Fallback: EFI framebuffer
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FB_SIMPLE=y
CONFIG_DRM_SIMPLEDRM=y

# PCI (required for DRM drivers)
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# === Serial console (needed for QEMU debug) ===
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=y

# === Console ===
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# === Input ===
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_INPUT_MOUSE=y
CONFIG_MOUSE_PS2=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_INPUT_JOYSTICK=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y

# === USB ===
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y

# === Audio (ALSA) ===
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_HDA=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_GENERIC=y
CONFIG_SND_HDA_CODEC_REALTEK=y
CONFIG_SND_HDA_CODEC_HDMI=y
CONFIG_SND_USB_AUDIO=y
CONFIG_SND_RAWMIDI=y
CONFIG_SND_SEQ_MIDI=y

# === Disable unnecessary subsystems ===
# CONFIG_NETWORK is not set
# CONFIG_WIRELESS is not set
# CONFIG_BLUETOOTH is not set
# CONFIG_WLAN is not set
# CONFIG_NET is not set
# CONFIG_SCSI is not set
# CONFIG_ATA is not set
# CONFIG_MD is not set
# CONFIG_CRYPTO is not set
# CONFIG_SECURITY is not set
# CONFIG_SELINUX is not set
# CONFIG_AUDIT is not set
# CONFIG_DEBUG_KERNEL is not set
CONFIG_PRINTK=y
# CONFIG_BUG is not set

# === Power management ===
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=y
CONFIG_SUSPEND=n
CONFIG_HIBERNATION=n
