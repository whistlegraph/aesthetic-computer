#!/bin/sh
# AC Native OS init — DRM direct boot with crash recovery

mount -t proc proc /proc 2>/dev/null
mount -t sysfs sysfs /sys 2>/dev/null
mount -t devtmpfs devtmpfs /dev 2>/dev/null
mkdir -p /dev/pts /dev/shm /tmp /run /etc
mount -t devpts devpts /dev/pts -o ptmxmode=0666 2>/dev/null
mount -t tmpfs tmpfs /dev/shm 2>/dev/null
mount -t tmpfs tmpfs /tmp 2>/dev/null
mount -t tmpfs tmpfs /run 2>/dev/null
mount -t efivarfs efivarfs /sys/firmware/efi/efivars 2>/dev/null

# zram swap
modprobe zram 2>/dev/null
echo 1G > /sys/block/zram0/disksize 2>/dev/null && mkswap /dev/zram0 >/dev/null 2>&1 && swapon /dev/zram0 2>/dev/null

# Loopback
ip link set lo up 2>/dev/null

# Restore baked Claude credentials (tmpfs mount hid the originals)
if [ -f /claude-creds.json ]; then
    mkdir -p /tmp/.claude
    cp /claude-creds.json /tmp/.claude/.credentials.json
    cp /claude-state.json /tmp/.claude.json 2>/dev/null
    printf '{"permissions":{"allow":["Bash(*)","Read(*)","Write(*)","Edit(*)","Glob(*)","Grep(*)","WebFetch(*)","WebSearch(*)"]},"autoUpdates":false,"installMethod":"native"}\n' > /tmp/.claude/settings.json
fi
mkdir -p /tmp/ac
[ -f /device-claude.md ] && cp /device-claude.md /tmp/ac/CLAUDE.md 2>/dev/null
[ -f /device-score.md ] && cp /device-score.md /tmp/ac/SCORE.md 2>/dev/null

# /etc/group and /etc/passwd needed by seatd
echo "root:x:0:" > /etc/group
echo "root:x:0:root" > /etc/passwd

# Wait for GPU (up to 3 seconds)
i=0
while [ ! -e /dev/dri/card0 ] && [ ! -e /dev/dri/card1 ] && [ ! -e /dev/fb0 ] && [ $i -lt 300 ]; do
    usleep 10000 2>/dev/null || sleep 1
    i=$((i+1))
done

# Performance governor
for g in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    echo performance > "$g" 2>/dev/null
done

export PATH="/bin:/sbin:/usr/bin:/usr/sbin"
export SSL_CERT_FILE="/etc/pki/tls/certs/ca-bundle.crt"
export CURL_CA_BUNDLE="/etc/pki/tls/certs/ca-bundle.crt"
export SSL_CERT_DIR="/etc/ssl/certs"
export HOME="/tmp"

# ── WiFi auto-connect ──
# Mount USB EFI partition to read saved credentials
USB_PART=""
for p in /dev/sda1 /dev/sdb1 /dev/nvme0n1p1; do
    if [ -b "$p" ]; then
        mkdir -p /mnt
        mount -t vfat "$p" /mnt 2>/dev/null && {
            if [ -f /mnt/EFI/BOOT/BOOTX64.EFI ]; then USB_PART="$p"; break; fi
            umount /mnt 2>/dev/null
        }
    fi
done

# Find wireless interface
WLAN=""
for d in /sys/class/net/wlan* /sys/class/net/wlp*; do
    [ -d "$d" ] && WLAN=$(basename "$d") && break
done

if [ -n "$WLAN" ]; then
    ip link set "$WLAN" up 2>/dev/null
    mkdir -p /var/run/wpa_supplicant /etc/wpa_supplicant

    # Build wpa_supplicant config from saved creds or default hotspot
    WPA_CONF="/etc/wpa_supplicant/wpa_supplicant.conf"
    cat > "$WPA_CONF" <<WPAEOF
ctrl_interface=/var/run/wpa_supplicant
update_config=1
WPAEOF

    # Read saved WiFi credentials from USB
    if [ -f /mnt/wifi_creds.json ] && command -v busybox >/dev/null; then
        # Simple JSON array parse: extract ssid/pass pairs
        # Format: [{"ssid":"name","pass":"pw"}, ...]
        cat /mnt/wifi_creds.json | sed 's/},{/}\n{/g' | while read -r line; do
            SSID=$(echo "$line" | sed -n 's/.*"ssid"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
            PASS=$(echo "$line" | sed -n 's/.*"pass"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
            if [ -n "$SSID" ] && [ -n "$PASS" ]; then
                cat >> "$WPA_CONF" <<NETEOF
network={
    ssid="$SSID"
    psk="$PASS"
}
NETEOF
            fi
        done
    fi

    # Always add default hotspot
    cat >> "$WPA_CONF" <<DEFEOF
network={
    ssid="aesthetic.computer"
    psk="aesthetic.computer"
}
DEFEOF

    # Start wpa_supplicant in background
    wpa_supplicant -B -i "$WLAN" -c "$WPA_CONF" 2>/dev/null

    # Start dhclient in background (will get IP when WiFi connects)
    (sleep 5 && dhclient -nw "$WLAN" 2>/dev/null) &
fi

# Run ac-native in a loop — if it crashes, restart; if clean exit, shutdown
CRASH_COUNT=0
while true; do
    /ac-native /piece.mjs
    EXIT_CODE=$?

    # Clean exit (0) = shutdown requested
    if [ "$EXIT_CODE" = "0" ]; then
        sync
        poweroff -f 2>/dev/null || reboot -f 2>/dev/null
        sleep 10
        break
    fi

    CRASH_COUNT=$((CRASH_COUNT + 1))

    # Flash screen red via framebuffer
    if [ -c /dev/fb0 ]; then
        dd if=/dev/zero bs=4096 count=512 2>/dev/null | tr '\0' '\377' > /dev/fb0 2>/dev/null
    fi

    sleep 2
done
