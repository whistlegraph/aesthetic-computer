<Page x:Class="Aesthetic.DynamicShell.MainPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Background="#120F1A">
    <WebView x:Name="Browser" NavigationStarting="OnNavigationStarting" NavigationCompleted="OnNavigationCompleted" ScriptNotify="OnScriptNotify" />
    <Border x:Name="SettingsPanel" Visibility="Collapsed" Background="#E6120F1A" Padding="36" HorizontalAlignment="Center" VerticalAlignment="Center" Width="820">
      <StackPanel>
        <TextBlock Text="AC endpoint" Foreground="White" FontSize="32" Margin="0,0,0,20" />
        <TextBox x:Name="EndpointBox" FontSize="24" IsSpellCheckEnabled="False" />
        <TextBlock Text="Press A/Enter to save and load. Press B/Escape to cancel." Foreground="#CCFFFFFF" FontSize="18" Margin="0,18,0,0" />
      </StackPanel>
    </Border>
    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="24" Padding="12,7" Background="#B0000000">
      <TextBlock x:Name="Status" Foreground="White" FontFamily="Consolas" FontSize="14" Text="starting" />
    </Border>
  </Grid>
</Page>
