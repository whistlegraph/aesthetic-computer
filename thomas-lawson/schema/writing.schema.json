{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "writing.schema.json",
  "title": "Writing",
  "description": "A text by or about Thomas Lawson — essay, review, interview, anthology entry, etc.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier (nanoid)"
    },
    "title": {
      "type": "string",
      "description": "Title of the writing"
    },
    "slug": {
      "type": "string",
      "description": "URL-safe identifier",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$"
    },
    "year": {
      "type": ["integer", "null"],
      "description": "Year of publication",
      "minimum": 1950,
      "maximum": 2030
    },
    "type": {
      "type": "string",
      "enum": ["essay", "review", "interview", "anthology", "book", "catalogue-text", "article", "other"],
      "description": "Type of writing"
    },
    "author": {
      "type": ["string", "null"],
      "description": "Author name — null if by Lawson, otherwise the other author's name"
    },
    "publication": {
      "type": ["string", "null"],
      "description": "Publication name (e.g. 'Artforum', 'Afterall', 'East of Borneo', 'REALLIFE')"
    },
    "issue": {
      "type": ["string", "null"],
      "description": "Issue number or volume info"
    },
    "url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "External link to the text if available online"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "caption": { "type": ["string", "null"] }
        },
        "required": ["url"]
      }
    },
    "description": {
      "type": ["string", "null"],
      "description": "Brief summary or notes"
    },
    "artworkIds": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of artworks discussed in this writing"
    },
    "sourceUrl": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Original page URL on thomaslawson.com"
    },
    "category": {
      "type": "string",
      "enum": ["afterall", "artforum", "east-of-borneo", "reallife", "anthologies", "interviews", "considering-other-artists", "writings-about-tl"],
      "description": "Bookshelf category from the site"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "title", "slug", "type", "category"]
}
