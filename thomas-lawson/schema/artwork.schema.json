{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artwork.schema.json",
  "title": "Artwork",
  "description": "A visual artwork by Thomas Lawson (painting, installation, mixed media, etc.) — aligned with Schema.org VisualArtwork",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier (nanoid)"
    },
    "serial": {
      "type": "string",
      "description": "Short deterministic serial number (e.g. 'TL-A3F9K') — consistent across re-scrapes",
      "pattern": "^TL\\d+$"
    },
    "title": {
      "type": "string",
      "description": "Artwork title (Schema.org: name)"
    },
    "slug": {
      "type": "string",
      "description": "URL-safe identifier derived from title",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$"
    },
    "year": {
      "type": ["integer", "null"],
      "description": "Year of creation (Schema.org: dateCreated)",
      "minimum": 1950,
      "maximum": 2030
    },
    "yearEnd": {
      "type": ["integer", "null"],
      "description": "End year if work spans a range (e.g. 2001-2003)",
      "minimum": 1950,
      "maximum": 2030
    },
    "type": {
      "type": "string",
      "enum": ["painting", "installation", "work-on-paper", "mixed-media", "book", "other"],
      "description": "Primary artwork type (Schema.org: artform)"
    },
    "medium": {
      "type": ["string", "null"],
      "description": "Full freeform medium string as written (e.g. 'oilstick and enamel paint on canvas, with painted wooden frame')"
    },
    "artMedium": {
      "type": ["string", "null"],
      "description": "Primary material/medium (Schema.org: artMedium — e.g. 'oil', 'acrylic', 'oilstick')"
    },
    "artworkSurface": {
      "type": ["string", "null"],
      "description": "Support surface (Schema.org: artworkSurface — e.g. 'canvas', 'paper', 'linen', 'board')"
    },
    "dimensions": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "properties": {
            "width": { "type": "number", "description": "Width in specified unit" },
            "height": { "type": "number", "description": "Height in specified unit" },
            "depth": { "type": ["number", "null"], "description": "Depth for 3D works" },
            "unit": { "type": "string", "enum": ["in", "cm", "ft", "m"], "default": "in" },
            "text": { "type": ["string", "null"], "description": "Original dimension string as written (e.g. '110 X 150 in. (25 sheets, 22 X 30 in. each)')" }
          },
          "required": ["width", "height", "unit"]
        }
      ]
    },
    "artEdition": {
      "type": ["string", "null"],
      "description": "Edition info for prints/multiples (Schema.org: artEdition — e.g. '1/5', 'AP')"
    },
    "series": {
      "type": ["string", "null"],
      "description": "Series name if part of one (e.g. 'Dis-', 'Roman Head', 'Viennese Painting')"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Freeform tags for categorization"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri", "description": "Image URL" },
          "caption": { "type": ["string", "null"], "description": "Image caption" },
          "primary": { "type": "boolean", "default": false, "description": "Whether this is the primary/representative image" },
          "isDetail": { "type": "boolean", "default": false, "description": "Whether this image is a detail/closeup of the artwork" },
          "detailLabel": { "type": ["string", "null"], "description": "Label for the detail view (e.g. 'Running Figures', 'upper left corner')" },
          "credit": { "type": ["string", "null"], "description": "Photographer or image credit" },
          "wpMediaId": { "type": ["integer", "null"], "description": "WordPress media library ID for cross-referencing" }
        },
        "required": ["url"]
      },
      "minItems": 1
    },
    "description": {
      "type": ["string", "null"],
      "description": "Extended description or contextual notes"
    },
    "collection": {
      "type": ["string", "null"],
      "description": "Current collection or owner (e.g. 'Tate, London', 'Hammer Museum')"
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "owner": { "type": "string" },
          "acquired": { "type": ["string", "null"], "description": "Year or date acquired" },
          "notes": { "type": ["string", "null"] }
        },
        "required": ["owner"]
      },
      "description": "Ownership history"
    },
    "exhibitions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of exhibitions this artwork appeared in"
    },
    "writingIds": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of related writings (essays, reviews, etc.)"
    },
    "sourceUrl": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Original page URL on thomaslawson.com"
    },
    "section": {
      "type": "string",
      "enum": ["in-the-studio", "beyond-the-studio", "art-in-a-broader-context"],
      "description": "Site section the artwork was scraped from"
    },
    "period": {
      "type": ["string", "null"],
      "description": "Period slug from site (e.g. '1977-1979', '2017-2020')"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "title", "slug", "type", "images", "section"]
}
