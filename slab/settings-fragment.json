{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "@HOME@/.local/bin/claude-stop.sh", "async": true }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "@HOME@/.local/bin/claude-subagent-stop.sh", "async": true }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "@HOME@/.local/bin/claude-tool-pre.sh", "async": true }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "@HOME@/.local/bin/claude-prompt-log.sh", "async": true }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "@HOME@/.local/bin/claude-notify.sh", "async": true }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "@HOME@/.local/bin/slab-cancel-pending", "async": true }
        ]
      }
    ]
  }
}
