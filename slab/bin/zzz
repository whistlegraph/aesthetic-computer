#!/usr/bin/env node
// zzz — park prompt processes and wake their provider threads later.
//
//   zzz                         tappable sleeping-prompt harness
//   zzz list [--json]           non-interactive inventory
//   zzz resume [id|number|text] resume one sleeping prompt (latest by default)
//   zzz wake [id|number|text]   alias for resume
//   zzz park <id|prefix|pid>    park one tracked idle prompt
//   zzz park <pid> --force      explicitly park an untracked/working prompt

import {
  chmod, mkdir, readFile, readdir, rename, rm, stat, writeFile,
} from "node:fs/promises";
import { execFile } from "node:child_process";
import { promisify } from "node:util";
import { basename, dirname, join } from "node:path";
import { homedir } from "node:os";

const execFileAsync = promisify(execFile);
const HOME_DIR = homedir();
const SLAB_HOME = process.env.SLAB_HOME || join(HOME_DIR, ".local", "share", "slab");
const SLAB_BIN = process.env.SLAB_BIN || join(HOME_DIR, ".local", "bin");
const STATE = join(SLAB_HOME, "state");
const ZZZ_DIR = join(STATE, "zzz");
const ACTIVE_DIR = join(STATE, "active-prompts");
const AWAITING_DIR = join(STATE, "awaiting-prompts");
const RUNNING_DIR = join(STATE, "running-tools");
const LOOPBOY = join(HOME_DIR, ".config", "slab", "loopboy.json");

const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
const readJson = async (path) => {
  try { return JSON.parse(await readFile(path, "utf8")); } catch { return null; }
};
const exists = async (path) => { try { await stat(path); return true; } catch { return false; } };
const shellQuote = (value) => `'${String(value).replaceAll("'", "'\\''")}'`;
const clean = (value) => String(value || "").replace(/\s+/g, " ").trim();
const short = (value, n = 60) => {
  const s = clean(value);
  return s.length <= n ? s : `${s.slice(0, n - 1)}…`;
};

async function entries() {
  let names = [];
  try { names = await readdir(ZZZ_DIR); } catch { return []; }
  const rows = (await Promise.all(names.filter((name) => name.endsWith(".json"))
    .map((name) => readJson(join(ZZZ_DIR, name))))).filter(Boolean);
  return rows.sort((a, b) => Date.parse(b.parkedAt || 0) - Date.parse(a.parkedAt || 0));
}

async function atomicWrite(path, value) {
  await mkdir(dirname(path), { recursive: true });
  const tmp = `${path}.${process.pid}.tmp`;
  await writeFile(tmp, `${JSON.stringify(value, null, 2)}\n`, { mode: 0o600 });
  await rename(tmp, path);
}

function resolve(rows, query) {
  const q = clean(query).toLowerCase();
  if (!q) return [];
  let hits = rows.filter((row) => String(row.id).toLowerCase() === q);
  if (hits.length) return hits;
  hits = rows.filter((row) => String(row.id).toLowerCase().startsWith(q)
    || String(row.providerSessionId || "").toLowerCase().startsWith(q));
  if (hits.length) return hits;
  if (/^\d+$/.test(q)) {
    const index = Number(q) - 1;
    if (rows[index]) return [rows[index]];
  }
  return rows.filter((row) => clean(row.subject).toLowerCase().includes(q));
}

function wakeCommand(entry) {
  const cwd = shellQuote(entry.cwd);
  if (entry.agentType === "codex") {
    const launcher = join(SLAB_BIN, "codex-slab");
    return `cd ${cwd} && exec ${shellQuote(launcher)} resume ${shellQuote(entry.providerSessionId)}`;
  }
  const launcher = join(SLAB_BIN, "claude");
  return `cd ${cwd} && exec ${shellQuote(launcher)} -r ${shellQuote(entry.providerSessionId || entry.id)}`;
}

async function wake(entry) {
  if (!entry?.cwd || !entry?.providerSessionId) throw new Error("sleeping entry lacks cwd/provider session id");
  const command = wakeCommand(entry);
  if (process.env.ZZZ_DRY_RUN === "1") return { command, dryRun: true };

  const launchDir = join(SLAB_HOME, "launches");
  await mkdir(launchDir, { recursive: true });
  const launchPath = join(launchDir, `zzz-${process.pid}-${Date.now()}.command`);
  const script = `#!/bin/zsh\nrm -f ${shellQuote(launchPath)}\n${command}\n`;
  await writeFile(launchPath, script, { mode: 0o700 });
  await chmod(launchPath, 0o700);
  try {
    await execFileAsync("/usr/bin/open", ["-a", "Terminal", launchPath]);
  } catch (error) {
    await rm(launchPath, { force: true });
    throw new Error(`Terminal rejected wake: ${error.message}`);
  }
  await rm(join(ZZZ_DIR, `${entry.id}.json`), { force: true });
  return { command, dryRun: false };
}

const pidAlive = (pid) => {
  try { process.kill(pid, 0); return true; }
  catch (error) { return error?.code === "EPERM"; }
};

async function ancestorPids(pid = process.pid) {
  const result = new Set();
  let current = pid;
  for (let i = 0; i < 40 && current > 1; i++) {
    try {
      const { stdout } = await execFileAsync("/bin/ps", ["-o", "ppid=", "-p", String(current)]);
      const parent = Number(stdout.trim());
      if (!parent || parent <= 1 || result.has(parent)) break;
      result.add(parent);
      current = parent;
    } catch { break; }
  }
  return result;
}

async function loopboyIds() {
  const obj = await readJson(LOOPBOY);
  return new Set(Object.values(obj?.loops || {}).map((loop) => loop?.sessionId).filter(Boolean));
}

async function trackedPrompts() {
  let names = [];
  try { names = await readdir(ACTIVE_DIR); } catch { return []; }
  const rows = [];
  for (const name of names.filter((value) => !value.startsWith("."))) {
    const marker = await readJson(join(ACTIVE_DIR, name));
    if (!marker) continue;
    const awaiting = await readFile(join(AWAITING_DIR, name), "utf8").catch(() => "");
    const running = await exists(join(RUNNING_DIR, name));
    let status = marker.state === "blank" ? "blank" : "working";
    if (awaiting.toLowerCase().startsWith("turn complete")) status = "complete";
    else if (awaiting) status = "awaiting";
    else if (!running && Date.now() - Date.parse(marker.updated || 0) > 45_000) status = "interrupted";
    rows.push({ ...marker, session_id: marker.session_id || name, status });
  }
  return rows;
}

async function providerFromProcess(pid) {
  const { stdout = "" } = await execFileAsync("/bin/ps", ["-o", "command=", "-p", String(pid)]).catch(() => ({}));
  return stdout.match(/\bcodex(?:-slab)?\s+resume\s+([0-9a-f-]{36})\b/i)?.[1] || "";
}

async function markerForPid(pid) {
  const { stdout = "" } = await execFileAsync("/bin/ps", ["-o", "tty=,command=", "-p", String(pid)]).catch(() => ({}));
  const line = stdout.trim();
  if (!line) return null;
  const firstSpace = line.search(/\s/);
  const tty = firstSpace < 0 ? "" : line.slice(0, firstSpace);
  const command = firstSpace < 0 ? line : line.slice(firstSpace).trim();
  const agentType = /\bcodex\b/i.test(command) ? "codex" : (/\bclaude\b/i.test(command) ? "claude" : "");
  if (!agentType) return null;
  const providerSessionId = agentType === "codex" ? await providerFromProcess(pid) : "";
  let cwd = "";
  try {
    const { stdout: lsof } = await execFileAsync("/usr/sbin/lsof", ["-a", "-p", String(pid), "-d", "cwd", "-Fn"]);
    cwd = lsof.split("\n").find((value) => value.startsWith("n"))?.slice(1) || "";
  } catch {}
  return {
    session_id: providerSessionId || `pid-${pid}`,
    agent_type: agentType,
    agent_pid: pid,
    codex_session_id: providerSessionId,
    cwd,
    tty,
    subject: command,
    summary: agentType,
    updated: new Date().toISOString(),
    status: "untracked",
  };
}

async function leaveResumeReceipt(entry) {
  if (process.env.ZZZ_DRY_RUN === "1") return;
  const ttyName = basename(String(entry.tty || ""));
  if (!/^tty[a-zA-Z0-9._-]+$/.test(ttyName)) return;
  const resume = `zzz resume ${String(entry.id).slice(0, 8)}`;
  const receipt = [
    "\r\n\x1b[1;38;5;213m💤  ZZZ parked this prompt\x1b[0m",
    `\x1b[2m${short(entry.subject, 72)}\x1b[0m`,
    `\x1b[1;38;5;51mResume: ${resume}\x1b[0m`,
    "",
  ].join("\r\n");
  const ttyRoot = process.env.ZZZ_TTY_ROOT || "/dev";
  await writeFile(join(ttyRoot, ttyName), receipt, { flag: "a" }).catch(() => {});
}

async function park(marker, { force = false } = {}) {
  const sid = marker.session_id;
  const pid = Number(marker.agent_pid || marker.claude_pid || 0);
  if (!sid || !pid || !marker.tty || !marker.cwd) throw new Error("prompt lacks resumable session/pid/tty/cwd metadata");
  if (!force && marker.status !== "complete" && marker.status !== "interrupted") {
    throw new Error(`refusing to zzz ${marker.status || "working"} prompt without --force`);
  }
  if (!force && (await loopboyIds()).has(sid)) throw new Error("refusing to zzz a Loopboy-bound prompt");
  if ((await ancestorPids()).has(pid)) throw new Error("refusing to zzz the session running this harness");
  const providerSessionId = marker.agent_type === "codex"
    ? (marker.codex_session_id || await providerFromProcess(pid)) : sid;
  if (!providerSessionId) throw new Error("Codex provider thread is unknown; refresh tracking before zzz");

  const entry = {
    version: 1,
    id: sid,
    providerSessionId,
    agentType: marker.agent_type || "claude",
    cwd: marker.cwd,
    subject: marker.subject || `${marker.agent_type || "agent"} session`,
    summary: marker.summary || marker.agent_type || "agent",
    tty: marker.tty,
    parkedAt: new Date().toISOString(),
    lastActiveAt: marker.updated || new Date().toISOString(),
    reason: force ? "manual-force" : "manual",
  };
  await mkdir(ZZZ_DIR, { recursive: true });
  await atomicWrite(join(ZZZ_DIR, `${sid}.json`), entry);
  if (process.env.ZZZ_DRY_RUN !== "1") {
    if (pidAlive(pid)) { try { process.kill(pid, "SIGTERM"); } catch {} }
    for (let i = 0; i < 6 && pidAlive(pid); i++) await sleep(200);
    if (pidAlive(pid)) { try { process.kill(pid, "SIGKILL"); } catch {} }
    await sleep(100);
    if (pidAlive(pid)) {
      await rm(join(ZZZ_DIR, `${sid}.json`), { force: true });
      throw new Error(`could not stop pid ${pid}; wake record rolled back`);
    }
    // Keep the terminal surface as the durable receipt. Closing it made the
    // parked prompt look like a crash and erased the only useful next step.
    await leaveResumeReceipt(entry);
    await Promise.all([
      rm(join(ACTIVE_DIR, sid), { force: true }),
      rm(join(AWAITING_DIR, sid), { force: true }),
      rm(join(RUNNING_DIR, sid), { force: true }),
    ]);
  }
  return entry;
}

function age(when) {
  const seconds = Math.max(0, Math.floor((Date.now() - Date.parse(when || 0)) / 1000));
  if (seconds < 60) return `${seconds}s`;
  if (seconds < 3600) return `${Math.floor(seconds / 60)}m`;
  if (seconds < 86400) return `${Math.floor(seconds / 3600)}h`;
  return `${Math.floor(seconds / 86400)}d`;
}

async function harness() {
  if (!process.stdin.isTTY || !process.stdout.isTTY) {
    await printList(false);
    return;
  }
  let selected = 0;
  let rows = [];
  let busy = false;
  let restored = false;
  const rowStart = 5;
  const write = (value) => process.stdout.write(value);
  const restore = () => {
    if (restored) return;
    restored = true;
    write("\x1b[?1000l\x1b[?1006l\x1b[?25h\x1b[?1049l");
    if (process.stdin.isRaw) process.stdin.setRawMode(false);
  };
  const render = async (message = "") => {
    rows = await entries();
    selected = Math.max(0, Math.min(selected, rows.length - 1));
    write("\x1b[2J\x1b[H");
    write("\x1b[1;35mzzz\x1b[0m  sleeping prompt harness\n");
    write("tap a row or use ↑/↓ + Return · r refresh · q quit\n\n");
    write(`\x1b[2mSleeping prompts (${rows.length})\x1b[0m\n`);
    if (!rows.length) write("  nothing sleeping — Slab will park eligible idle prompts here\n");
    rows.forEach((entry, index) => {
      const cursor = index === selected ? "\x1b[7m" : "";
      const cwd = basename(entry.cwd || "") || entry.cwd || "?";
      write(`${cursor} ${String(index + 1).padStart(2)}  ${entry.agentType === "codex" ? "C" : "A"}  ${short(entry.subject, 54).padEnd(54)}  ${cwd}  ${age(entry.parkedAt)} \x1b[0m\n`);
    });
    if (message) write(`\n\x1b[36m${message}\x1b[0m`);
  };
  const wakeSelected = async () => {
    if (busy || !rows[selected]) return;
    busy = true;
    try {
      const entry = rows[selected];
      await render(`waking ${short(entry.subject, 45)}…`);
      await wake(entry);
      await render(`woke ${short(entry.subject, 45)}`);
    } catch (error) {
      await render(`wake failed: ${error.message}`);
    } finally { busy = false; }
  };

  write("\x1b[?1049h\x1b[?25l\x1b[?1000h\x1b[?1006h");
  process.stdin.setRawMode(true);
  process.stdin.resume();
  await render();
  process.on("exit", restore);
  process.on("SIGINT", () => { restore(); process.exit(0); });
  process.on("SIGTERM", () => { restore(); process.exit(0); });
  process.stdin.on("data", async (chunk) => {
    const input = chunk.toString("utf8");
    if (input === "q" || input === "\u0003") { restore(); process.exit(0); }
    if (input.includes("\x1b[A")) { selected = Math.max(0, selected - 1); await render(); return; }
    if (input.includes("\x1b[B")) { selected = Math.min(rows.length - 1, selected + 1); await render(); return; }
    if (input === "\r" || input === "\n") { await wakeSelected(); return; }
    if (input === "r") { await render("refreshed"); return; }
    const mouse = input.match(/\x1b\[<0;\d+;(\d+)[Mm]/);
    if (mouse) {
      const index = Number(mouse[1]) - rowStart;
      if (index >= 0 && index < rows.length) {
        selected = index;
        await render();
        await wakeSelected();
      }
    }
  });
}

async function printList(json) {
  const rows = await entries();
  if (json) { process.stdout.write(`${JSON.stringify(rows, null, 2)}\n`); return; }
  if (!rows.length) { console.log("zzz: no sleeping prompts"); return; }
  rows.forEach((entry, index) => {
    console.log(`${String(index + 1).padStart(2)}  ${entry.agentType.padEnd(6)}  ${age(entry.parkedAt).padStart(4)}  ${short(entry.subject)}  ·  ${entry.cwd}`);
    console.log(`    resume: zzz resume ${index + 1}`);
  });
  console.log("\nresume the newest: zzz resume");
}

function usage() {
  console.log("usage: zzz [list [--json] | resume [id|number|text] | wake [id|number|text] | park <id|pid> [--force]]");
}

async function main() {
  const [command, query, ...rest] = process.argv.slice(2);
  if (!command) { await harness(); return; }
  if (command === "list") { await printList(process.argv.includes("--json")); return; }
  if (command === "wake" || command === "resume") {
    const rows = await entries();
    const hits = query ? resolve(rows, query) : rows.slice(0, 1);
    if (!hits.length) throw new Error(`no sleeping prompt matches «${query || ""}»`);
    if (hits.length > 1) throw new Error(`ambiguous sleeping prompt: ${hits.map((row) => short(row.subject, 24)).join(", ")}`);
    await wake(hits[0]);
    console.log(`woke ${hits[0].agentType} · ${short(hits[0].subject)}`);
    return;
  }
  if (command === "park") {
    const force = rest.includes("--force") || process.argv.includes("--force");
    let marker;
    if (/^\d+$/.test(query || "")) marker = await markerForPid(Number(query));
    else {
      const prompts = await trackedPrompts();
      const matches = prompts.filter((row) => row.session_id === query
        || row.session_id.toLowerCase().startsWith(String(query || "").toLowerCase())
        || clean(row.subject).toLowerCase().includes(String(query || "").toLowerCase()));
      if (matches.length > 1) throw new Error(`ambiguous live prompt (${matches.length} matches)`);
      marker = matches[0];
    }
    if (!marker) throw new Error(`no live prompt matches «${query || ""}»`);
    const entry = await park(marker, { force });
    console.log(`zzz'd ${entry.agentType} · ${short(entry.subject)}`);
    console.log(`resume: zzz resume ${String(entry.id).slice(0, 8)}`);
    return;
  }
  usage();
  process.exitCode = 2;
}

main().catch((error) => {
  console.error(`zzz: ${error.message}`);
  process.exitCode = 1;
});
