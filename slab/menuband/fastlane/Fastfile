# Menu Band — Mac App Store submission, driven by an App Store Connect API key.
# Usage: fastlane create   /   fastlane meta   /   fastlane ship
# (run from slab/menuband; the API key .p8 lives at ~/.appstoreconnect/private_keys/)

API_KEY_ID = "S4TQKG6U99" # Admin role — required for cloud signing (cert/profile creation)
API_ISSUER = "69a6de78-fa3c-47e3-e053-5b8c7c11a4d1"
API_KEY_PATH = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_S4TQKG6U99.p8")
BUNDLE = "computer.aesthetic.menuband"
PKG = "/tmp/MenuBand-export/Menu Band.pkg"

def asc_key
  app_store_connect_api_key(
    key_id: API_KEY_ID,
    issuer_id: API_ISSUER,
    key_filepath: API_KEY_PATH,
    in_house: false,
  )
end

platform :mac do
  # 2b. Upload screenshots ONLY (skip_metadata avoids the review-attachment
  #     code path in deliver's metadata uploader). Safe to re-run.
  lane :shots do
    deliver(
      api_key: asc_key,
      platform: "osx",
      app_identifier: BUNDLE,
      screenshots_path: "./fastlane/screenshots",
      skip_metadata: true,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      submit_for_review: false,
      force: true,
      run_precheck_before_submit: false,
    )
  end

  # 1. Create the App Store Connect app record (idempotent — no-op if it exists).
  lane :create do
    asc_key # sets Spaceship::ConnectAPI token globally for produce
    produce(
      app_identifier: BUNDLE,
      app_name: "Menu Band",
      language: "en-US",
      sku: "menuband",
      platform: "osx",
    )
  end

  # 2. Upload metadata + screenshots only (no binary, no submit). Safe to re-run.
  lane :meta do
    deliver(
      api_key: asc_key,
      platform: "osx",
      app_identifier: BUNDLE,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
      overwrite_screenshots: true,
      skip_binary_upload: true,
      submit_for_review: false,
      force: true,
      run_precheck_before_submit: false,
    )
  end

  # 3. Upload the .pkg only (kicks off App Store processing).
  lane :upload do
    deliver(
      api_key: asc_key,
      platform: "osx",
      app_identifier: BUNDLE,
      pkg: PKG,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      force: true,
      run_precheck_before_submit: false,
    )
  end

  # 3b. Publish the App Privacy nutrition label ("Data Not Collected").
  #     The public ASC API has no appDataUsages endpoint; this action drives
  #     Apple's private dataUsages routes with the same API key.
  lane :privacy do
    upload_app_privacy_details(
      api_key: asc_key,
      app_identifier: BUNDLE,
      json_path: "./fastlane/app_privacy_details.json",
    )
  end

  # 4. Submit for review (build must be processed + price/agreements set).
  lane :ship do
    deliver(
      api_key: asc_key,
      platform: "osx",
      app_identifier: BUNDLE,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
      overwrite_screenshots: true,
      skip_binary_upload: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
      },
    )
  end
end
