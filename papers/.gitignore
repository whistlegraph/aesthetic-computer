# Ignore build-artifact PDFs inside paper source dirs
# (published PDFs live in system/public/papers.aesthetic.computer/)
arxiv-*/*.pdf
arxiv-*/*.aux
arxiv-*/*.bbl
arxiv-*/*.blg
arxiv-*/*.log
arxiv-*/*.out
arxiv-*/*.toc

# Build-time version stamp (git hash + revision), regenerated by
# cli.mjs stampVersion() on every build — never commit it, or the oven's
# clean-tree regeneration would diff against the dirty-tree value and loop.
arxiv-*/version.tex
arxiv-*/history.tex
