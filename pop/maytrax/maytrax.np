# maytrax — placeholder vocal score. matrix/prodigy energy, F minor.
# vocal range C4-F5 (jeffrey-pvc singable). NOTE:syllable*beats; '-' continues.
# the drops want SHOUTS, not melodic lines — short, percussive, 1-2 beats.

verse 1
# drop 1 hook — "wake up / it's real / hold on / let go"
F4:wake*1 F4:up*1
G#4:its*1 G4:real*2
F4:hold*1 F4:on*1
C5:let*1 C5:go*2

verse 2
# drop 2 hook — "follow / the white / rabbit / now"
F4:fol-*1 F4:-low*1
G#4:the*1 G4:white*2
F4:rab-*1 F4:-bit*1
C5:now*4
