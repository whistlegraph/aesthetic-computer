# reference corpus stays vault-only — never commit third-party lyrics
references/*
!references/README.md

# track outputs
big-pictures/out/
hum/out/
hellsine/out/
maytrax/out/

# RFA recorded voice takes — local performances, kept off the repo
# (the manifest.json punch-list IS tracked)
**/voice-takes/*.wav

# pop/samples/ — third-party reference audio (downloaded from YouTube etc.)
# The audio + chops stay local; manifest.json + INDEX.json + onsets.json
# are tracked so the recipe is reproducible from the URL.
samples/*/source.*
samples/*/chops/
