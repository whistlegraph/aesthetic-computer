# marketing — keep prompts + processes, skip outputs.
# gens/ holds gpt-image-2 PNGs (large, regen-able from cover-prompt.txt + refs).
# captures/ holds local puppeteer captures from `bin/capture-ac-native.mjs`.
campaigns/*/gens/
captures/

# story videos — keep vo.txt + build.mjs, skip rendered/cached output.
campaigns/*/story/build/
campaigns/*/story/*.mp4
campaigns/*/story/*.mp3
campaigns/*/story/*.alignment.json
campaigns/*/story/*.hash
kidlisp-reels/out/

# podcast — keep the pipeline (bin/, SCORE.md), skip rendered audio + say cache.
# jingles regenerate from jingle.mjs; episodes + say cache are large/regen-able.
podcast/out/
podcast/assets/
podcast/publish/

# av-reels working outputs (regen-able)
av-reels/out/
