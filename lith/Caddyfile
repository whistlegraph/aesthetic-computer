    # --- ipfs.aesthetic.computer (self-hosted IPFS gateway) ---
    # Kubo emits Access-Control-Allow-Origin: * on its own. An earlier Caddy
    # `header` directive was stacking a second copy, producing "*, *" that
    # browsers reject. Let Kubo own the header, Caddy just proxies.
    @ipfs host ipfs.aesthetic.computer
    handle @ipfs {
        reverse_proxy localhost:8090
    }

