    @keepsredirect host keeps.kidlisp.com
    handle @keepsredirect {
        redir https://keep.kidlisp.com{uri} 301
    }

    @keepsac host keeps.aesthetic.computer
    handle @keepsac {
        reverse_proxy localhost:8888
    }

    # --- jas.life ---
