        handle /js/* {
            root * /opt/ac/system/public/kidlisp.com
            file_server
        }
        handle /qr/* {
            root * /opt/ac/system/public/kidlisp.com
            rewrite * /qr.html
            file_server
        }
        handle {
            root * /opt/ac/system/public/kidlisp.com
            rewrite * /device.html
            file_server
        }
    }

    @topcalm host top.kidlisp.com calm.kidlisp.com
    handle @topcalm {
