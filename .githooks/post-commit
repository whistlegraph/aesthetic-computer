#!/usr/bin/env bash
# Post-commit hook:
# 1) log the commit event to local agent memory
# 2) import recent Codex messages into local memory
# 3) flush remote queue (no-op unless remote sync is enabled)
# 4) auto-deploy landing page to silo when it changes

set -u

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "${REPO_ROOT:-}" ]; then
  exit 0
fi

NODE_BIN="${NODE_BIN:-node}"
if ! command -v "$NODE_BIN" >/dev/null 2>&1; then
  exit 0
fi

# Agent memory
"$NODE_BIN" "$REPO_ROOT/memory/hook.mjs" post-commit >/dev/null 2>&1 || true
"$NODE_BIN" "$REPO_ROOT/memory/codex-sync.mjs" --max-sessions 3 --max-events 120 >/dev/null 2>&1 || true
"$NODE_BIN" "$REPO_ROOT/memory/cli.mjs" flush-remote >/dev/null 2>&1 || true

# Auto-deploy landing page to silo when it changes
if git diff-tree --no-commit-id --name-only -r HEAD | grep -q "feed/landing-page.html"; then
  echo "📺 Landing page changed — deploying to silo..."
  fish "$REPO_ROOT/feed/deploy-silo.fish" --landing 2>&1 | tail -3 &
fi

exit 0
